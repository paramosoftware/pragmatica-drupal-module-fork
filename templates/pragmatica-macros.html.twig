{% macro renderField(field) %}
  <div class="mb-3">
    <label for="{{ field.name }}" class="form-label">{{ field.label }}</label>
    <br>

    {% if field.type == 'select' %}
      {% set selected = field.value ?? [] %}
      <select name="{{ field.name }}" id="{{ field.name }}" {{ field.multiple ? 'multiple' : '' }} class="form-control" data-multiplejs="true">
        {% for value, label in field.options %}
          <option value="{{ value }}" {% if value in selected %}selected{% endif %}>{{ label }}</option>
        {% endfor %}
      </select>

    {% elseif field.type == 'number' %}
      <input type="number" name="{{ field.name }}" id="{{ field.name }}" value="{{ field.value }}" min="{{ field.min }}" max="{{ field.max }}" class="form-control" />

    {% elseif field.type == 'text' %}
      <input type="text" name="{{ field.name }}" id="{{ field.name }}" value="{{ field.value }}" />

    {% else %}
      <p class="error">Unsupported field type: {{ field.type }}</p>
    {% endif %}
  </div>
{% endmacro %}


{% macro label_badge(label, add_tooltip = true, add_url = true) %}
  {% set has_selections = label.selections is defined and label.selections is not empty %}
  {% set text_color = label.text_color ?? '#ffffff' %}
  <span
    class="badge badge-square text-uppercase align-center me-1 text-center d-inline-flex align-items-center pragmatica-label-badge"
    style="background-color: {{ label.color }}; color: {{ text_color }};"
    data-bs-toggle="tooltip"
    data-bs-placement="bottom"
    title="{{ add_tooltip ? label.label : '' }}"
    {% if has_selections %}
    data-selections="{{ label.selections|json_encode }}"
    data-color="{{ label.color }}"
    {% endif %}
  >
    {% if add_url %}
      <a href="{{ label.url }}" class="hover-link">{{ label.code }}</a>
    {% else %}
      {{ label.code }}
    {% endif %}
    {% if has_selections %}
      <button
        class="pragmatica-pin-btn"
        type="button"
        title="{{ 'Fixar destaque'|t }}"
        aria-pressed="false"
        tabindex="-1"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M4.146.146A.5.5 0 0 1 4.5 0h7a.5.5 0 0 1 .5.5c0 .68-.342 1.174-.646 1.479-.126.125-.25.224-.354.298v4.431l.078.048c.203.127.476.314.751.555C12.36 7.775 13 8.527 13 9.5a.5.5 0 0 1-.5.5h-4v4.5c0 .276-.224 1.5-.5 1.5s-.5-1.224-.5-1.5V10h-4a.5.5 0 0 1-.5-.5c0-.973.64-1.725 1.17-2.189A5.921 5.921 0 0 1 5 6.787V2.351a2.205 2.205 0 0 1-.354-.298C4.342 1.674 4 1.179 4 .5a.5.5 0 0 1 .146-.354z"/>
        </svg>
      </button>
    {% endif %}
  </span>
{% endmacro %}


{% macro response_card(content, content_url, header_left, header_right, labels, count, add_header_tooltip = true) %}
  <div class="card border rounded-0 shadow-sm mb-3">
    <div class="card-header bg-light text-muted rounded-0 py-1 d-flex
      {% if header_left is null and count is defined %}
      justify-content-start
      gap-4
      {%  else %}
      justify-content-between
      align-items-center"
      {% endif %}
    >
      {% if header_left is null and count is defined %}
        <a href="#" class="text-muted hover-link me-3 mb-4" data-bs-toggle="tooltip"  data-bs-html="true"> {{ count }}</a>
      {%  else %}
        {{ _self._response_card_header(header_left, add_header_tooltip) }}
      {% endif %}
      {{ _self._response_card_header(header_right, add_header_tooltip) }}
    </div>
    <div class="card-body">
      <p class="card-text mb-3">
        <span class="pragmatica-response-text">{{ content|raw }}</span>
        <a href="{{ content_url }}" target="_blank">
          »
        </a>
      </p>
      <div>
        {% for label in labels %}
          {{ _self.label_badge(label) }}
        {% endfor %}
      </div>
    </div>
  </div>
{% endmacro %}

{% macro _response_card_header(header, add_tooltip = true) %}
  <a 
    href="{{ header.url }}" 
    class="text-muted hover-link" 
    data-bs-toggle="tooltip" 
    data-bs-html="true" 
    title="{{ add_tooltip ? ('<div>' ~ _self.label_attributes(header) ~ '</div>') : '' }}"
  >
    {{ header.label }}
  </a>
{% endmacro %}

{% macro label_attributes(
  entity, 
  add_linebreaks = true, 
  label_class = 'fw-semibold', 
  value_class = '',
  wrapper_class = 'd-block',
) %}
  {% if entity._attributes is defined %}
    {% for label, value in entity._attributes %}
    <div class="{{ wrapper_class }}">
      <span class="{{ label_class }}">{{ label }}: </span> 
      <span class="{{ value_class }}">{{ value }}</span>
    </div>
    {% endfor %}
  {% endif %}
{% endmacro %}


{% macro pager(pager, form_id = 'pragmatica-search-form', select_id = 'pragmatica-page-select') %}
  {% if pager.total_pages > 1 %}
    <div class="d-flex align-items-center my-2">
      <nav aria-label="Page navigation">
        <ul class="pagination mb-0">
          {% if pager.current > 0 %}
            <li class="page-item"><a class="page-link pragmatica-page-link" href="#" data-page="{{ pager.current - 1 }}">&laquo;</a></li>
          {% endif %}

          {% for p in pager.pages %}
            <li class="page-item {% if p.is_current %}active{% endif %}">
              <a class="page-link pragmatica-page-link" href="#" data-page="{{ p.index }}">{{ p.label }}</a>
            </li>
          {% endfor %}

          {% if pager.current + 1 < pager.total_pages %}
            <li class="page-item"><a class="page-link pragmatica-page-link" href="#" data-page="{{ pager.current + 1 }}">&raquo;</a></li>
          {% endif %}
        </ul>
      </nav>

      <div class="ms-3 d-flex align-items-center">
        {# <label for="{{ select_id }}" class="me-2 mb-0 small">{{ 'Ir para'|t }}</label> #}
        <select id="{{ select_id }}" class="form-select" aria-label="{{ 'Selecionar página'|t }}">
          {% for j in 0..(pager.total_pages - 1) %}
            <option value="{{ j }}" {% if j == pager.current %}selected{% endif %}>{{ j + 1 }}</option>
          {% endfor %}
        </select>
      </div>
    </div>

    <script>
    (function () {
      var form = document.getElementById('{{ form_id }}');
      if (!form) return;
      var pageInput = form.querySelector('input[name="page"]');
      if (!pageInput) {
        pageInput = document.createElement('input');
        pageInput.type = 'hidden';
        pageInput.name = 'page';
        pageInput.value = '{{ pager.current|default(0) }}';
        form.appendChild(pageInput);
      }

      var pageLinks = document.querySelectorAll('#' + '{{ form_id }}' + ' .pragmatica-page-link, .' + 'pragmatica-page-link');
      Array.prototype.forEach.call(pageLinks, function(el) {
        el.addEventListener('click', function(e) {
          e.preventDefault();
          form.dataset.paginating = '1';
          var target = el.getAttribute('data-page');
          pageInput.value = target;
          var select = document.getElementById('{{ select_id }}');
          if (select) select.value = target;
          form.submit();
        });
      });

      var select = document.getElementById('{{ select_id }}');
      if (select) {
        select.addEventListener('change', function() {
          form.dataset.paginating = '1';
          pageInput.value = this.value;
          form.submit();
        });
      }

      form.addEventListener('submit', function() {
        if (this.dataset.paginating !== '1') {
          pageInput.value = 0;
        } else {
          delete this.dataset.paginating;
        }
      });
    })();
    </script>
  {% endif %}
{% endmacro %}



